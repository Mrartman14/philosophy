{
  "name": "philosophy",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "dev:https": "next dev --experimental-https",
    "build": "node scripts/generate-sw-assets.mjs && tsx scripts/generate-tokens.mjs && next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:tokens": "tsx scripts/generate-tokens.mjs",
    "generate:api": "pnpm exec swagger2openapi ${SWAGGER_URL:-../philosophy-api/docs/swagger/swagger.json} -o /tmp/openapi3.json && pnpm exec openapi-typescript /tmp/openapi3.json -o src/api/schema.ts"
  },
  "packageManager": "pnpm@8.14.3",
  "pnpm": {
    "//": "unrs-resolver's napi-postinstall 'check' script is redundant — the native binding is installed via the platform optionalDependency (@unrs/resolver-binding-*) — and its bin shim fails to resolve on re-install under node-linker=hoisted, making `pnpm install` exit 1. Skipping it keeps installs clean; the resolver still loads.",
    "neverBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-cell": "^3.22.3",
    "@tiptap/extension-table-header": "^3.22.3",
    "@tiptap/extension-table-row": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "idb": "^8.0.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.5",
    "apca-w3": "^0.1.9",
    "apcach": "^0.6.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "culori": "^4.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-vitest": "^0.5.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "swagger2openapi": "7.0.8",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
