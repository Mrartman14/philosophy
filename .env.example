# Публичный конфиг сборки — безопасно коммитить.
# Реальные значения живут в .env.production / .env.development.

# Базовый URL и путь приложения (вшиваются в клиентский бандл через Next.js)
NEXT_PUBLIC_BASE_URL=https://example.com
NEXT_PUBLIC_BASE_PATH=/philosophy

# VAPID-публичный ключ НЕ является env-переменной на фронтенде:
# он запрашивается у бэкенда в runtime через GET /api/push/vapid-key.
# Не добавляй NEXT_PUBLIC_VAPID_PUBLIC_KEY в env-файлы фронтенда.

# VAPID_PRIVATE_KEY — секрет ТОЛЬКО бэкенда.
# Он никогда не должен находиться в этом репозитории.
# Бэкенд читает его из своих переменных окружения (например, Railway/Heroku secrets).
# VAPID_PRIVATE_KEY=<backend-only — never commit here>
